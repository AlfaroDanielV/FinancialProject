# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finance:finance@localhost:5432/finance

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-32-char-string

# ── Single-user MVP ───────────────────────────────────────────────────────────
# Run `python scripts/create_user.py --name "Tu Nombre"` after migrations
# to generate this value.
DEFAULT_USER_ID=

# ── iPhone Shortcut auth ──────────────────────────────────────────────────────
# Set this to any long random string; add it as X-Shortcut-Token header in the Shortcut
SHORTCUT_TOKEN=change-me-to-a-random-token
