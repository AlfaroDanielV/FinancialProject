# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finance:finance@localhost:5432/finance

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model used by the Telegram LLM extractor. Default is Haiku; swap to Sonnet
# (e.g. claude-sonnet-4-6) if CR-slang fixture tests reveal accuracy gaps.
LLM_EXTRACTION_MODEL=claude-haiku-4-5
# Soft daily token cap per user before the bot politely refuses (Phase 5b).
LLM_DAILY_TOKEN_BUDGET_PER_USER=100000

# ── Telegram (Phase 5b) ───────────────────────────────────────────────────────
# Mode must be one of: disabled | polling | webhook.
#   disabled — no bot is started (default, CI-safe).
#   polling  — long-poll, runs as a background task on app startup.
#   webhook  — the app registers a webhook at TELEGRAM_WEBHOOK_URL and
#              validates every request against TELEGRAM_WEBHOOK_SECRET.
TELEGRAM_MODE=disabled
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-32-char-string
# Stdout log level for the production container. DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# ── Production deployment notes ───────────────────────────────────────────────
# When deploying (Container Apps / any container host) override the values
# above with the managed equivalents:
#   DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DB?ssl=require
#   REDIS_URL=rediss://:PASSWORD@HOST:6380/0
#   ENVIRONMENT=production
#   LOG_LEVEL=INFO
#   TELEGRAM_MODE=webhook
#   TELEGRAM_WEBHOOK_URL=https://api.your-domain.com/api/v1/telegram/webhook
#   TELEGRAM_WEBHOOK_SECRET=<random 32 bytes>
# Auth note: there is no global SHORTCUT_SECRET — every user owns an opaque
# users.shortcut_token returned once at /users/register. Do not introduce a
# global secret env var.

# ── Gmail / OAuth (Phase 6b) ──────────────────────────────────────────────────
# See docs/phase-6b/gcp-setup.md. Daniel sets up one Google Cloud project
# (Testing mode), gets these credentials, and adds beta testers manually as
# Test users. The flow is OAuth Authorization Code with scope=gmail.readonly.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Must match an Authorized redirect URI registered in GCP exactly.
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/gmail/oauth/callback
# HS256 secret used to sign the OAuth `state` JWT. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
GMAIL_OAUTH_STATE_SECRET=
# Telegram batching threshold. If a single scan finds more than N new
# transactions, send one aggregated summary instead of N messages.
GMAIL_BATCH_THRESHOLD=5

# ── Secret store (Phase 6b) ───────────────────────────────────────────────────
# `env`      — reads/writes refresh tokens from env vars prefixed DEV_SECRET_.
#              Process-local. Lost on uvicorn restart. Good for tests / CI.
# `file`     — JSON file `.dev_secrets.json` in cwd (gitignored). Persists
#              across restarts. Recommended for local dev iterating on Gmail.
# `azure_kv` — Azure Key Vault using DefaultAzureCredential (managed identity
#              in Container Apps, `az login` locally). Production.
SECRET_STORE_BACKEND=env
AZURE_KEY_VAULT_URL=
# Optional: override the path used by SECRET_STORE_BACKEND=file. Defaults
# to `.dev_secrets.json` in the current working directory.
FILE_SECRET_STORE_PATH=

# ── Phase 5a migration: legacy user backfill ──────────────────────────────────
# Required ONLY when running `alembic upgrade head` to apply migration 0006
# against a database that has Phase 1–4 data. The migration:
#   - Updates the existing users.id row matching DEFAULT_USER_ID (if set).
#   - Else falls back to matching by email; else inserts a fresh user.
#   - Backfills user_id on every domain table.
# After 0006 is applied you can remove these from .env (the app does not read
# them at runtime).
LEGACY_USER_EMAIL=you@example.com
LEGACY_USER_NAME=Tu Nombre
LEGACY_SHORTCUT_TOKEN=paste-the-token-the-iphone-shortcut-has-here
# Optional: only set if you have an existing user row to preserve (was
# DEFAULT_USER_ID in the pre-Phase-5a config).
DEFAULT_USER_ID=
