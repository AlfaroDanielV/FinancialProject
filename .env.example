# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finance:finance@localhost:5432/finance

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-32-char-string

# ── Phase 5a migration: legacy user backfill ──────────────────────────────────
# Required ONLY when running `alembic upgrade head` to apply migration 0006
# against a database that has Phase 1–4 data. The migration:
#   - Updates the existing users.id row matching DEFAULT_USER_ID (if set).
#   - Else falls back to matching by email; else inserts a fresh user.
#   - Backfills user_id on every domain table.
# After 0006 is applied you can remove these from .env (the app does not read
# them at runtime).
LEGACY_USER_EMAIL=you@example.com
LEGACY_USER_NAME=Tu Nombre
LEGACY_SHORTCUT_TOKEN=paste-the-token-the-iphone-shortcut-has-here
# Optional: only set if you have an existing user row to preserve (was
# DEFAULT_USER_ID in the pre-Phase-5a config).
DEFAULT_USER_ID=
